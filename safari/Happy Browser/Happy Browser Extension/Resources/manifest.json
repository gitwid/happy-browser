{
  "manifest_version": 3,
  "name": "Trillian",
  "description": "Adds blind previous and next navigation to pages with arrows, gestures, and large page controls.",
  "version": "0.3.0",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.wikipedia.org/*"
      ],
      "js": [
        "src/wikipedia-link-preview.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "src/navigation-scoring.js",
        "src/navigation-outcome.js",
        "src/navigation-rail.js",
        "src/content.js"
      ],
      "css": [
        "src/content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-happy": {
      "suggested_key": {
        "default": "Alt+Shift+H",
        "mac": "Alt+Shift+H"
      },
      "description": "Toggle Happy Browser on this page"
    }
  },
  "action": {
    "default_title": "Trillian",
    "default_popup": "src/options.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/wikipedia-popups-guard.js"
      ],
      "matches": [
        "*://*.wikipedia.org/*"
      ]
    }
  ],
  "background": {
    "service_worker": "src/background.js"
  }
}
